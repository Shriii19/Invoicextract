# InvoiceXtract Environment Variables Template
# Copy this file to .env and update values as needed

# Logging
LOG_LEVEL=INFO

# PDF Processing
PDF_MAX_FILE_SIZE=52428800  # 50MB in bytes

# OCR Settings
OCR_ENABLED=false
OCR_LANGUAGE=en
OCR_GPU_ENABLED=false

# Extraction Settings
CONFIDENCE_THRESHOLD=0.7
BATCH_SIZE=10

# Export Settings
DEFAULT_EXPORT_FORMAT=csv

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Database (for future use)
DATABASE_URL=sqlite:///./invoicextract.db

# Other Settings
# Add your custom environment variables here
